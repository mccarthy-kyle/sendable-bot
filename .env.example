# Discord
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
# Optional: set to register commands instantly to one server during dev.
# Leave blank for global registration (~1hr to propagate).
GUILD_ID=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Storage (Railway: point at a mounted volume, e.g. /data/sendable.db)
DATABASE_PATH=./data/sendable.db
